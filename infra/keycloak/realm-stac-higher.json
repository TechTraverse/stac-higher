{
  "realm": "stac-higher",
  "displayName": "STAC Higher",
  "enabled": true,
  "registrationAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "member",
        "description": "View group connections and associate them with collections"
      },
      {
        "name": "operator",
        "description": "Create, edit, and operate group connections"
      },
      {
        "name": "admin",
        "description": "Cross-group administration"
      }
    ]
  },
  "groups": [
    {
      "name": "earth-observation",
      "path": "/earth-observation",
      "realmRoles": [
        "member"
      ]
    },
    {
      "name": "weather",
      "path": "/weather",
      "realmRoles": [
        "member"
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@stac-higher.local",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Operator",
      "credentials": [
        {
          "type": "password",
          "value": "alice-password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "operator"
      ],
      "groups": [
        "/earth-observation"
      ]
    },
    {
      "username": "bob",
      "enabled": true,
      "email": "bob@stac-higher.local",
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "Member",
      "credentials": [
        {
          "type": "password",
          "value": "bob-password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "member"
      ],
      "groups": [
        "/weather"
      ]
    },
    {
      "username": "carol",
      "enabled": true,
      "email": "carol@stac-higher.local",
      "emailVerified": true,
      "firstName": "Carol",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "carol-password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ],
      "groups": []
    }
  ],
  "clients": [
    {
      "clientId": "stac-higher-app",
      "name": "STAC Higher app",
      "description": "Public OIDC client for the Astro app (authorization code + PKCE)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:4321/*"
      ],
      "webOrigins": [
        "http://localhost:4321"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:4321/*"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "claim.name": "groups",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "stac-higher-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "stac-higher",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "stac-higher-test",
      "name": "STAC Higher integration tests",
      "description": "LOCAL-ONLY confidential client with direct-access (password) grants for integration tests. Never deploy. See docs/decisions/0002-auth-proxy-enforcement.md.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "stac-higher-test-secret",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [],
      "webOrigins": [],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "claim.name": "groups",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "stac-higher-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "stac-higher",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "stac-higher-test-noaud",
      "name": "STAC Higher integration tests (no audience)",
      "description": "LOCAL-ONLY twin of stac-higher-test without the audience mapper, for negative (wrong-audience) integration tests. Never deploy.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "stac-higher-test-noaud-secret",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [],
      "webOrigins": [],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "claim.name": "groups",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ]
}